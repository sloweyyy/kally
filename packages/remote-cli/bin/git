#!/bin/sh
# Thor git wrapper — wires GIT_ASKPASS to the Thor helper when GitHub App
# auth is configured. Git only invokes askpass when a remote operation
# actually needs credentials, so local commands avoid the Node startup cost.
# Falls back to PAT auth (GH_TOKEN / GIT_ASKPASS) when GitHub App is not configured.

set -e

REAL_GIT="/usr/bin/git"

# If no GitHub App config exists, pass through to real git unchanged
if [ ! -f /workspace/config.json ] || ! grep -q '"github_app"' /workspace/config.json 2>/dev/null; then
  exec "$REAL_GIT" "$@"
fi

export GIT_ASKPASS="/usr/local/lib/thor/bin/git-askpass"
export GIT_TERMINAL_PROMPT=0
export GIT_CONFIG_COUNT=1
export GIT_CONFIG_KEY_0="credential.username"
export GIT_CONFIG_VALUE_0="x-access-token"
exec "$REAL_GIT" "$@"
