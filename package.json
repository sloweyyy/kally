{
  "name": "thor",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mcp": "npx tsx scripts/test-mcp.ts",
    "test:e2e": "./scripts/test-e2e.sh",
    "test:opencode-e2e": "./scripts/test-opencode-e2e.sh",
    "test:sandbox-e2e": "./scripts/test-sandbox-e2e.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  }
}
