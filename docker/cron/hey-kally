#!/bin/sh
set -e

KEY=""
while [ $# -gt 1 ]; do
  case "$1" in
    --key) KEY="$2"; shift 2 ;;
    *) break ;;
  esac
done

[ -z "$1" ] && { echo "Usage: hey-kally [--key <key>] '<prompt>'"; exit 1; }

echo "[hey-kally] prompt length: ${#1}"
echo "[hey-kally] prompt preview: $(printf '%.80s' "$1")..."

DIR=$(printf '%s' "$PWD" | jq -Rs .)
PROMPT=$(printf '%s' "$1" | jq -Rs .)
JSON="{\"prompt\":${PROMPT},\"directory\":${DIR}}"
[ -n "$KEY" ] && JSON="{\"prompt\":${PROMPT},\"correlationKey\":$(printf '%s' "$KEY" | jq -Rs .),\"directory\":${DIR}}"

echo "[hey-kally] json length: ${#JSON}"
echo "[hey-kally] posting to ${GATEWAY_URL}/cron"

printf '%s' "$JSON" | curl -v -X POST "${GATEWAY_URL}/cron" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${CRON_SECRET}" \
  -d @- 2>&1

echo ""
echo "[hey-kally] exit code: $?"
