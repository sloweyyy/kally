      }
    },
    {
      "host_suffix": ".internal.example",
      "headers": {
        "Authorization": "Bearer ${INTERNAL_API_TOKEN}"
      },
      "readonly": true
    }
  ],
  "mitmproxy_passthrough": ["api.openai.com", ".anthropic.com"]
