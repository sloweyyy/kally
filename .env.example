# Environment variables required for Thor
# Copy this file to .env and fill in the values.

# ── CRON — shared secret for scheduled job auth ──────────────────────────────
CRON_SECRET=generate-a-random-secret

# ── DATA — credential-injecting reverse proxy for internal APIs ──────────────
# Set DATA_ROUTES to a comma-separated list of route names, then define
# each route's upstream URL, API key, and optional header name.
# If DATA_ROUTES is empty, the proxy falls back to httpbin.org for testing.
#
# DATA_ROUTES=billing,analytics
# DATA_ROUTE_billing_UPSTREAM=https://billing.example.com/
# DATA_ROUTE_billing_KEY=sk-your-api-key
# DATA_ROUTE_billing_HEADER=X-Custom-Auth
# DATA_ROUTE_analytics_UPSTREAM=https://analytics.example.com/
# DATA_ROUTE_analytics_KEY=sk-your-other-key

# ── GIT — author identity for commits made by Thor ───────────────────────────
# GIT_USER_NAME=Thor
# GIT_USER_EMAIL=thor@your-domain.com

# ── GRAFANA — service account token for Loki/Tempo queries ─────────────────
GRAFANA_URL=https://your-instance.grafana.net
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── ATLASSIAN — Atlassian MCP (scoped API token with Basic auth) ───────────
# Generate: echo -n "you@example.com:ATATT3x_YOUR_SCOPED_TOKEN" | base64
ATLASSIAN_BASIC_AUTH=base64_encoded_email_colon_token

# ── GITHUB — personal access token for git-mcp and GitHub MCP proxy ─────────
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── LINEAR — API key for Linear workspace read access ────────────────────────
LINEAR_API_KEY=lin_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── POSTHOG — personal API key (use the "MCP Server" preset) ────────────────
POSTHOG_API_KEY=phx_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OPENCODE — resource limits and session configuration ─────────────────────
# OPENCODE_CPU_LIMIT=3
# OPENCODE_MEMORY_LIMIT=4g

# ── SLACK — bot token and webhook verification ───────────────────────────────
# Create a Slack app with Events API subscription and the `app_mentions:read`
# and `chat:write` bot scopes.
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_SIGNING_SECRET=
# SLACK_TIMESTAMP_TOLERANCE_SECONDS=300

# ── WORKSPACE — repo config file (channel mapping, working directories) ──────
# WORKSPACE_CONFIG=/workspace/repos.json

# ── VOUCH — Google SSO for ingress auth ──────────────────────────────────────
VOUCH_GOOGLE_CLIENT_ID=your-google-client-id
VOUCH_GOOGLE_CLIENT_SECRET=your-google-client-secret
VOUCH_JWT_SECRET=generate-a-random-secret
VOUCH_WHITELIST=alice@example.com,bob@example.com
# VOUCH_CALLBACK_URL=http://localhost:8080/vouch/auth
# VOUCH_COOKIE_DOMAIN=localhost
