# Environment variables required for Thor
# Copy this file to .env and fill in the values.
# Note: base URL vars (RUNNER_URL, OPENCODE_URL, METABASE_URL, GITHUB_API_URL,
# SLACK_API_BASE_URL, etc.) must NOT have a trailing slash.

# ── CRON — shared secret for scheduled job auth ──────────────────────────────
CRON_SECRET=generate-a-random-secret

# ── INTERNAL — shared secret for gateway↔remote-cli internal APIs ───────────
THOR_INTERNAL_SECRET=generate-a-random-secret

# ── RUNNER — public base URL for Thor trigger viewer links ──────────────────
# Used by remote-cli when it appends "View trigger" links to PR/Jira text.
# Local ingress default:
RUNNER_BASE_URL=http://localhost:8080

# Hard cap on per-session JSONL log size in bytes. Above this value, the viewer
# returns the truncated state and findActiveTrigger fails closed. Default 50 MiB.
# SESSION_LOG_MAX_BYTES=52428800

# ── MITMPROXY — explicit outbound proxy for opencode clients ─────────────────
# Request path: opencode -> HTTP(S)_PROXY -> mitmproxy -> upstream.
# Routing is explicit through proxy env vars; there is no transparent intercept
# or firewall-level enforcement in this setup.
#
# Supported outbound clients for this workflow are:
#   - curl
#   - Node 22 built-in fetch()
#
# Put host rules in docker-volumes/workspace/config.json under `mitmproxy[]`
# and `mitmproxy_passthrough[]`. Keep secrets in .env and reference them from
# config.json via ${ENV_VAR} placeholders.
#
# Built-in defaults:
#   - inject Atlassian Authorization from ATLASSIAN_AUTH
#   - inject Slack Authorization Bearer token from SLACK_BOT_TOKEN
#   - passthrough OpenAI + ChatGPT domains without credential injection
#
# Example custom secret vars used by config.json rules:
# BILLING_API_KEY=sk-your-api-key
# INTERNAL_API_TOKEN=your-internal-token

# ── GRAFANA — service account token for Loki/Tempo queries ─────────────────
GRAFANA_URL=https://your-instance.grafana.net
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional — defaults to 1. Set to target a specific Grafana org.
GRAFANA_ORG_ID=1

# ── ATLASSIAN — Atlassian MCP authorization header value ───────────────────
# Supports two authentication methods:
#
# 1. Service account API key (Bearer auth, recommended):
#    ATLASSIAN_AUTH=Bearer ATSTT3x_YOUR_SERVICE_ACCOUNT_API_KEY
#
# 2. Personal API token (Basic auth):
#    Generate: echo -n "you@example.com:ATATT3x_YOUR_SCOPED_TOKEN" | base64
#    ATLASSIAN_AUTH=Basic base64_encoded_email_colon_token
#
# See: https://support.atlassian.com/atlassian-rovo-mcp-server/docs/configuring-authentication-via-api-token/
ATLASSIAN_AUTH=Bearer YOUR_TOKEN_HERE

# ── LANGFUSE — LLM observability (read-only trace queries) ──────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
LANGFUSE_SECRET_KEY=sk-lf-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── LAUNCHDARKLY — read-only feature flag inspection via ldcli ─────────────
# Create a Reader-scoped access token in LaunchDarkly:
# https://app.launchdarkly.com/settings/authorization/access-tokens
# LD_ACCESS_TOKEN=api-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# LD_BASE_URI=https://app.launchdarkly.com
# LD_PROJECT=default
# LD_ENVIRONMENT=production

# ── GITHUB — authentication for git/gh in remote-cli ────────────────────────
# Optional fallback token for git/gh command execution
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# GitHub App (required for remote-cli/gateway startup)
# App identity and webhook verification are env-only.
# Per-owner installation IDs go in /workspace/config.json under:
#   owners.<owner>.github_app_installation_id
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=thor
GITHUB_APP_BOT_ID=49699333
GITHUB_APP_PRIVATE_KEY_FILE=/var/lib/remote-cli/github-app/private-key.pem
GITHUB_WEBHOOK_SECRET=replace-with-random-secret
# GITHUB_API_URL=https://api.github.com

# ── POSTHOG — personal API key (use the "MCP Server" preset) ────────────────
POSTHOG_API_KEY=phx_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── METABASE — data warehouse query access (read-only) ──────────────────────
# API key must be scoped to a read-only database role.
# METABASE_URL=https://metabase.example.com
# METABASE_API_KEY=mb_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# METABASE_DATABASE_ID=41
# METABASE_ALLOWED_SCHEMAS=dm_products,dm_growth,dm_revenue

# ── DAYTONA — cloud sandboxes for Python/Java/etc. ──────────────────────────
# See docs/daytona.md for setup instructions.
# DAYTONA_API_KEY=daytona_XXXXXXXXXXXX
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_SNAPSHOT=thor-sandbox  # optional; defaults to daytona-medium

# ── SLACK — remote-cli posting, bot token, and webhook verification ──────────
# Create a Slack app with Events API subscription and the `app_mentions:read`
# and `chat:write` bot scopes. The same bot token is used by remote-cli for
# controlled slack-post-message calls, by gateway for Slack Web API calls, and
# by mitmproxy for supported Slack read/reaction/upload auth injection.
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_SIGNING_SECRET=
# SLACK_TIMESTAMP_TOLERANCE_SECONDS=300

# ── VOUCH — Google SSO for ingress auth ──────────────────────────────────────
VOUCH_GOOGLE_CLIENT_ID=your-google-client-id
VOUCH_GOOGLE_CLIENT_SECRET=your-google-client-secret
VOUCH_JWT_SECRET=generate-a-random-secret
VOUCH_WHITELIST=alice@example.com,bob@example.com
# VOUCH_CALLBACK_URL=http://localhost:8080/vouch/auth
# VOUCH_COOKIE_DOMAIN=localhost
